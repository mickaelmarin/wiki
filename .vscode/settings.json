{
  "eslint.enable": true,
  "puglint.enable": true,
  "editor.formatOnSave": false,
  "editor.tabSize": 2,
  "eslint.validate": [
    "javascript",
    "vue"
  ],
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "i18n-ally.localesPaths": [
    "server/locales"
  ],
  "remote.SSH.httpsProxy": "",
  "remote.autoForwardPortsFallback": 0
}
